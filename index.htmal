<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gifu Service | 岐阜服务站</title>
    <style>
        body { font-family: "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", "Hiragino Sans", sans-serif; margin: 0; text-align: center; background: #f4f7f6; }
        .container { max-width: 800px; margin: auto; padding: 50px 20px; }
        h1 { color: #333; }
        .lang-switch { margin-bottom: 30px; }
        button { padding: 10px 20px; cursor: pointer; border: 1px solid #ddd; background: white; border-radius: 5px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 40px; }
        .card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: 0.3s; cursor: pointer; text-decoration: none; color: inherit; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 6px 12px rgba(0,0,0,0.15); border: 1px solid #007AFF; }
        .card i { font-size: 40px; display: block; margin-bottom: 15px; }
        .jp { display: none; } /* 默认显示中文 */
    </style>
</head>
<body>

<div class="container">
    <div class="lang-switch">
        <button onclick="showLang('zh')">中文</button>
        <button onclick="showLang('jp')">日本語</button>
    </div>

    <header>
        <h1 class="zh">你好！我在岐阜为您提供服务</h1>
        <h1 class="jp">こんにちは！岐阜でサポートいたします</h1>
    </header>

    <div class="grid">
        <a class="card" href="#">
            <span>🧼</span>
            <h3 class="zh">空调清洁</h3>
            <h3 class="jp">エアコンクリーニング</h3>
            <p class="zh">专业深度清洗，岐阜全域对应</p>
            <p class="jp">プロの洗浄、岐阜県内対応</p>
        </a>

        <a class="card" href="#">
            <span>💻</span>
            <h3 class="zh">电脑故障咨询</h3>
            <h3 class="jp">パソコン修理・相談</h3>
            <p class="zh">远程诊断及上门维修</p>
            <p class="jp">遠隔診断・訪問修理</p>
        </a>

        <a class="card" href="#">
            <span>📥</span>
            <h3 class="zh">常用软件下载</h3>
            <h3 class="jp">ソフトダウンロード</h3>
            <p class="zh">精选工具，安全快捷</p>
            <p class="jp">厳選ツール、安全・高速</p>
        </a>
    </div>
</div>

<script>
    function showLang(lang) {
        document.querySelectorAll('.zh').forEach(el => el.style.display = (lang === 'zh' ? 'block' : 'none'));
        document.querySelectorAll('.jp').forEach(el => el.style.display = (lang === 'jp' ? 'block' : 'none'));
    }
</script>

</body>
</html>